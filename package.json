{
  "name": "d3-cloud",
  "version": "2.0.0",
  "description": "Generate word clouds in JavaScript.",
  "keywords": [
    "word",
    "cloud",
    "tag",
    "visualization",
    "canvas"
  ],
  "homepage": "https://www.jasondavies.com/wordcloud/",
  "license": "BSD-3-Clause",
  "type": "module",
  "types": "./index.d.ts",
  "files": [
    "src/",
    "build/",
    "index.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "author": {
    "name": "Jason Davies",
    "url": "https://www.jasondavies.com/"
  },
  "main": "src/index.js",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./src/index.js"
    },
    "./build/d3-cloud.js": "./build/d3-cloud.js"
  },
  "unpkg": "build/d3-cloud.js",
  "jsdelivr": "build/d3-cloud.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasondavies/d3-cloud.git"
  },
  "scripts": {
    "build": "esbuild src/index.js --bundle --format=esm --platform=browser --target=es2015 --outfile=build/d3-cloud.js",
    "check:examples": "node --check examples/index.js && node --check examples/image-sprites.js && node --check examples/mask.js && node --check examples/node.js && node --check examples/font-loading.js && node --check examples/worker.js && node --check examples/worker-layout.js && node --check benchmark.js",
    "check:package": "npm test && npm run check:examples && npm pack --dry-run --cache .npm-cache",
    "pretest": "npm run build",
    "test": "node --test"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
